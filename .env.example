# Copy to `.env.local` and fill in values (`.env*` is gitignored).

# --- Supabase (Dashboard → Project Settings → API) ---
# Project URL, e.g. https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Use the "service_role" JWT for server-side scripts and backup (never expose in the browser).
SUPABASE_SERVICE_ROLE_KEY=

# Optional: newer dashboard "secret" API key (sb_secret_...) — some tools expect this name.
SUPABASE_SECRET_KEY=

# --- App ---
# Public CSV URL for the dashboard widget
CSV_URL=

# Admin login: secret for signing session cookies (min 16 characters).
# Required whenever NODE_ENV=production (Vercel, droplet, etc.). Without it, POST /api/admin/auth/login returns 503.
ADMIN_AUTH_SECRET=

# If the app is served over HTTP in production (e.g. droplet without TLS), set to 1 so the
# browser will store the admin session cookie. Prefer HTTPS instead when possible.
# ADMIN_SESSION_INSECURE_HTTP=1
