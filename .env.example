# Copy to `.env.local` and fill in values (`.env*` is gitignored).

# --- Supabase (Dashboard → Project Settings → API) ---
# Project URL, e.g. https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Use the "service_role" JWT for server-side scripts and backup (never expose in the browser).
SUPABASE_SERVICE_ROLE_KEY=

# Optional: newer dashboard "secret" API key (sb_secret_...) — some tools expect this name.
SUPABASE_SECRET_KEY=

# --- App ---
# Public CSV URL for the dashboard widget
CSV_URL=

# Admin login: secret for signing session cookies (min 16 characters).
# Required whenever NODE_ENV=production (Vercel, droplet, etc.). Without it, POST /api/admin/auth/login returns 503.
ADMIN_AUTH_SECRET=

# If the app is served over HTTP in production (e.g. droplet without TLS), set to 1 so the
# browser will store the admin session cookie. Prefer HTTPS instead when possible.
# ADMIN_SESSION_INSECURE_HTTP=1

# --- Telegram calendar due notifications ---
# Bot token from BotFather. Keep this secret and set it in deployment env vars, not in Git.
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs that receive pending reminder/expense notifications.
TELEGRAM_CHAT_IDS=

# Optional: shared secret for HTTP cron backup (system crontab on deploy uses .env.local automatically).
TELEGRAM_CRON_SECRET=

# --- J&T Booking Status sync (official jtexpress.ph track API) ---
# Manual "Sync from J&T" uses the official site. Set ONE captcha solver (or paste tokens from browser devtools):
# TWOCAPTCHA_API_KEY=
# CAPSOLVER_API_KEY=
# JNT_TRACKING_VERIFY=   # optional: ticket from track page captcha (short-lived)
# JNT_TRACKING_VCK=      # optional: randstr from track page captcha
# JNT_TRACKING_PROVIDER=official   # official | trackingmore (default: official when captcha set)
# TRACKINGMORE_API_KEY=  # optional third-party fallback
# JNT_TRACKING_CRON_SECRET=        # bearer for cron POST /api/admin/jnt-tracking/sync
